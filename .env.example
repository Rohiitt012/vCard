# Copy this file to .env and set your values.
# Without .env and DATABASE_URL, vCards (create/edit/delete/list) will not work.

# PostgreSQL connection (required for vCards, inquiries, subscriptions)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Optional: email when someone submits the contact form (Resend.com)
# RESEND_API_KEY="re_xxxx"
# RESEND_FROM="noreply@yourdomain.com"
